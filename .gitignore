# Unity generated
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/
ExportedObj/

# Meta files: ignore all, then re-include the ones that matter
*.meta
!/[Aa]ssets/**/*.meta
!/[Pp]ackages/**/*.meta

# Autogenerated VS/Rider solution and project files
*.csproj
*.unityproj
*.sln
*.booproj

# Visual Studio / Rider temp and user files
*.suo
*.tmp
*.user
*.userprefs
*.opendb
*.VC.db

# Debug symbols and databases
*.pidb
*.pdb
*.mdb
*.svd

# Unity crash report
sysinfo.txt

# Crashlytics
crashlytics-build.properties

# Build outputs
*.apk
*.aab
*.unitypackage
*.app

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Autogenerated JetBrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# IDE folders
.vs/
.vscode/
.idea/
.consulo/

# Gradle
.gradle/

# NuGet
*.nupkg
*.snupkg

# macOS
.DS_Store
._*
.AppleDouble
.LSOverride

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
[Dd]esktop.ini
$RECYCLE.BIN/

# Linux
.fuse_hidden*
.directory
.Trash-*
.nfs*